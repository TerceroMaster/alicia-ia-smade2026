@article {Pirmohamed15,
	author = {Pirmohamed, Munir and James, Sally and Meakin, Shaun and Green, Chris and Scott, Andrew K and Walley, Thomas J and Farrar, Keith and Park, B Kevin and Breckenridge, Alasdair M},
	title = {Adverse drug reactions as cause of admission to hospital: prospective analysis of 18 820 patients},
	volume = {329},
	number = {7456},
	pages = {15--19},
	year = {2004},
	doi = {10.1136/bmj.329.7456.15},
	publisher = {BMJ Publishing Group Ltd},
	abstract = {Objective To ascertain the current burden of adverse drug reactions (ADRs) through a prospective analysis of all admissions to hospital. Design Prospective observational study. Setting Two large general hospitals in Merseyside, England. Participants 18 820 patients aged \&gt; 16 years admitted over six months and assessed for cause of admission. Main outcome measures Prevalence of admissions due to an ADR, length of stay, avoidability, and outcome. Results There were 1225 admissions related to an ADR, giving a prevalence of 6.5\%, with the ADR directly leading to the admission in 80\% of cases. The median bed stay was eight days, accounting for 4\% of the hospital bed capacity. The projected annual cost of such admissions to the NHS is {\textsterling}466m ({\texteuro}706m, $847m). The overall fatality was 0.15\%. Most reactions were either definitely or possibly avoidable. Drugs most commonly implicated in causing these admissions included low dose aspirin, diuretics, warfarin, and non-steroidal anti-inflammatory drugs other than aspirin, the most common reaction being gastrointestinal bleeding. Conclusion The burden of ADRs on the NHS is high, accounting for considerable morbidity, mortality, and extra costs. Although many of the implicated drugs have proved benefit, measures need to be put into place to reduce the burden of ADRs and thereby further improve the benefit:harm ratio of the drugs.},
	issn = {0959-8138},
	URL = {https://www.bmj.com/content/329/7456/15},
	eprint = {https://www.bmj.com/content/329/7456/15.full.pdf},
	journal = {BMJ}
}
